<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="./support.js"></script>
<script src="./image-slot.js"></script>
</head>
<body>
<x-dc>
<helmet>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,500;0,700;0,800;1,400&amp;family=Noto+Sans+JP:wght@300;400;500;700&amp;display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="logo.png">
<link rel="apple-touch-icon" href="logo.png">
<style>
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{background:#F8FAFC;-webkit-font-smoothing:antialiased;}
  ::-webkit-scrollbar{width:8px;height:8px;}
  ::-webkit-scrollbar-track{background:#F0F4F8;}
  ::-webkit-scrollbar-thumb{background:rgba(30,58,138,0.18);border-radius:99px;}
  ::-webkit-scrollbar-thumb:hover{background:#FF9E80;}
  @keyframes fm-drift{from{transform:translate(0,0) scale(1);}to{transform:translate(3%,3%) scale(1.08);}}
  @keyframes fm-spin{to{transform:rotate(360deg);}}
  @keyframes fm-rotate{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
  @keyframes fm-marquee{to{transform:translateX(-50%);}}
  @keyframes fm-marquee-rev{from{transform:translateX(-50%);}to{transform:translateX(0);}}
  @keyframes fm-pulse{0%{box-shadow:0 0 0 0 rgba(255,158,128,0.55);}70%{box-shadow:0 0 0 20px rgba(255,158,128,0);}100%{box-shadow:0 0 0 0 rgba(255,158,128,0);}}
  @keyframes fm-bob{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
  @keyframes fm-rise{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:none;}}
  @keyframes fm-grow{from{transform:scaleX(0);}to{transform:scaleX(1);}}
  /* stop-motion jerky wobble (steps() => choppy カクカク feel) */
  @keyframes fm-jerk1{0%{transform:rotate(-1.5deg) translateY(0);}33%{transform:rotate(1deg) translateY(-2px);}66%{transform:rotate(-0.5deg) translateY(1px);}100%{transform:rotate(-1.5deg) translateY(0);}}
  @keyframes fm-jerk2{0%{transform:rotate(2deg) translateY(0);}33%{transform:rotate(-1deg) translateY(-2px);}66%{transform:rotate(1.5deg) translateY(1px);}100%{transform:rotate(2deg) translateY(0);}}
  @keyframes fm-jerk3{0%{transform:rotate(-1deg) translateY(0);}33%{transform:rotate(1.5deg) translateY(-2px);}66%{transform:rotate(-1deg) translateY(1px);}100%{transform:rotate(-1deg) translateY(0);}}
  .fm-jerk1{animation:fm-jerk1 1.5s steps(1,end) infinite;}
  .fm-jerk2{animation:fm-jerk2 1.4s steps(1,end) infinite;}
  .fm-jerk3{animation:fm-jerk3 1.6s steps(1,end) infinite;}
  @keyframes fm-ovin{from{transform:translateX(100%);}to{transform:translateX(0);}}
  @keyframes fm-ovout{from{transform:translateX(0);}to{transform:translateX(100%);}}
  @keyframes fm-ovcontent{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:none;}}
  [data-works-more]{transition:transform .25s,box-shadow .25s;}
  [data-works-more]:hover{transform:translateY(-3px);box-shadow:0 16px 32px rgba(0,0,0,0.28);}
  [data-works-card]{transition:transform .3s cubic-bezier(.16,1,.3,1);}
  [data-works-card]:hover{transform:translateY(-6px);}
  [data-works-close]:hover{background:#FF9E80 !important;color:#0E1F52 !important;border-color:#FF9E80 !important;}
  @media (max-width:900px){
    #fm-spine{display:none !important;}
    #fm-main{margin-left:0 !important;}
    #fm-burger{display:flex !important;}
    [data-col2]{grid-template-columns:1fr !important;}
    [data-col3]{grid-template-columns:1fr !important;}
    #fm-hero h1{font-size:clamp(50px,17vw,120px) !important;}
    #fm-cta{width:64px !important;height:64px !important;bottom:18px !important;right:18px !important;}
    .fm-vert{writing-mode:horizontal-tb !important;letter-spacing:0.16em !important;margin-top:14px !important;}
    .fm-stat{display:flex !important;align-items:baseline !important;flex-wrap:wrap !important;gap:4px 8px !important;}
    .fm-stat p{margin-top:0 !important;}
    .fm-why-num{font-size:21px !important;}
    .fm-why-h{font-size:24px !important;}
    .fm-why-en{font-size:15px !important;}
    #fm-works-overlay{left:0 !important;}
  }
</style>
</helmet>
<div id="fm-root" style="position:relative;min-height:100vh;background:#F8FAFC;color:#0F172A;font-family:'Noto Sans JP',sans-serif;overflow-x:hidden;">

  <!-- ambient backdrop -->
  <div style="position:fixed;inset:0;z-index:0;pointer-events:none;background-size:26px 26px;background-image:linear-gradient(to right,rgba(30,58,138,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(30,58,138,0.025) 1px,transparent 1px);"></div>
  <div style="position:fixed;top:-12vw;left:-6vw;width:64vw;height:64vw;border-radius:50%;z-index:0;pointer-events:none;background:radial-gradient(circle,rgba(217,231,247,0.85) 0%,rgba(255,255,255,0) 70%);animation:fm-drift 16s ease-in-out infinite alternate;"></div>
  <div style="position:fixed;bottom:-14vw;right:-8vw;width:62vw;height:62vw;border-radius:50%;z-index:0;pointer-events:none;background:radial-gradient(circle,rgba(255,158,128,0.18) 0%,rgba(255,255,255,0) 70%);animation:fm-drift 19s ease-in-out infinite alternate;animation-delay:-6s;"></div>

  <!-- ===== Left spine ===== -->
  <nav id="fm-spine" style="position:fixed;top:0;left:0;height:100vh;width:120px;z-index:50;display:flex;flex-direction:column;align-items:center;justify-content:space-between;padding:26px 0;background:rgba(255,255,255,0.55);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-right:1px solid rgba(255,255,255,0.7);">
    <div style="position:absolute;right:0;top:0;width:2px;height:100%;background:rgba(30,58,138,0.06);"></div>
    <div data-progress="" style="position:absolute;right:0;top:0;width:2px;height:0%;background:linear-gradient(#1E3A8A,#FF9E80);"></div>

    <a data-nav="top" href="#top" style="position:relative;width:58px;height:58px;border-radius:16px;background:#fff;border:1px solid rgba(255,255,255,0.9);box-shadow:0 4px 14px rgba(31,38,135,0.1);display:flex;align-items:center;justify-content:center;text-decoration:none;flex-shrink:0;overflow:hidden;">
      <img src="logo.png" alt="ふじもも" style="width:100%;height:100%;object-fit:cover;display:block;">
    </a>

    <div style="display:flex;flex-direction:column;align-items:stretch;gap:4px;width:100%;">
      <a data-nav="top" href="#top" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">00</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">TOP</span>
      </a>
      <a data-nav="about" href="#about" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">01</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">ABOUT</span>
      </a>
      <a data-nav="works" href="#works" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">02</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">WORKS</span>
      </a>
      <a data-nav="career" href="#career" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">03</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">CAREER</span>
      </a>
      <a data-nav="why" href="#why" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">04</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">WHY</span>
      </a>
      <a data-nav="skills" href="#skills" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">05</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">SKILLS</span>
      </a>
      <a data-nav="contact" href="#contact" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:10px 0;cursor:pointer;">
        <span data-ind="" style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:0;background:#FF9E80;border-radius:0 4px 4px 0;"></span>
        <span data-num="" style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;letter-spacing:-0.02em;color:rgba(30,58,138,0.38);">06</span>
        <span data-label="" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.2em;color:rgba(30,58,138,0.32);">TALK</span>
      </a>
    </div>

    <div style="display:flex;flex-direction:column;align-items:center;gap:14px;flex-shrink:0;">
      <div style="width:28px;height:28px;border-radius:8px;border:1.5px solid rgba(30,58,138,0.3);display:flex;align-items:center;justify-content:center;">
        <div style="width:10px;height:10px;border-radius:50%;border:1.5px solid rgba(30,58,138,0.4);"></div>
      </div>
      <span style="writing-mode:vertical-rl;font-family:'Montserrat',sans-serif;font-weight:700;font-size:8px;letter-spacing:0.3em;color:rgba(30,58,138,0.3);">OSAKA / JP</span>
    </div>
  </nav>

  <!-- ===== Mobile hamburger ===== -->
  <button id="fm-burger" style="display:none;position:fixed;top:16px;right:16px;z-index:80;width:50px;height:50px;border-radius:14px;border:1px solid rgba(255,255,255,0.7);background:rgba(255,255,255,0.7);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);box-shadow:0 6px 18px rgba(31,38,135,0.1);flex-direction:column;align-items:center;justify-content:center;gap:5px;cursor:pointer;">
    <span style="display:block;width:20px;height:2px;background:#1E3A8A;border-radius:2px;"></span>
    <span style="display:block;width:20px;height:2px;background:#1E3A8A;border-radius:2px;"></span>
    <span style="display:block;width:20px;height:2px;background:#1E3A8A;border-radius:2px;"></span>
  </button>
  <div id="fm-menu" style="display:none;position:fixed;inset:0;z-index:75;background:rgba(248,250,252,0.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);flex-direction:column;align-items:flex-start;justify-content:center;gap:6px;padding:40px;">
    <button id="fm-menu-close" style="position:absolute;top:20px;right:22px;width:46px;height:46px;border-radius:50%;border:1px solid rgba(30,58,138,0.15);background:#fff;color:#1E3A8A;font-size:20px;cursor:pointer;">✕</button>
    <a data-nav="top" href="#top" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">00</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">TOP</span></a>
    <a data-nav="about" href="#about" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">01</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">ABOUT</span></a>
    <a data-nav="works" href="#works" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">02</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">WORKS</span></a>
    <a data-nav="career" href="#career" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">03</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">CAREER</span></a>
    <a data-nav="why" href="#why" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">04</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">WHY ME</span></a>
    <a data-nav="skills" href="#skills" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">05</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">SKILLS</span></a>
    <a data-nav="contact" href="#contact" style="display:flex;align-items:baseline;gap:14px;text-decoration:none;padding:10px 0;"><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">06</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:30px;color:#1E3A8A;">CONTACT</span></a>
  </div>

  <!-- ===== Floating CONTACT ===== -->
  <button id="fm-cta" style="position:fixed;bottom:30px;right:30px;z-index:60;width:88px;height:88px;border-radius:50%;border:1px solid rgba(255,255,255,0.5);background:#FF9E80;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;animation:fm-pulse 2.8s ease-out infinite;box-shadow:0 12px 28px rgba(255,158,128,0.4);">
    <span class="fm-cta-inner" style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;font-family:'Montserrat',sans-serif;">
      <span style="font-weight:800;font-size:11px;letter-spacing:0.12em;">CONTACT</span>
      <span style="font-size:14px;line-height:1;">↗</span>
    </span>
  </button>

  <!-- ===== Main ===== -->
  <main id="fm-main" style="position:relative;z-index:10;margin-left:120px;">

    <!-- HERO -->
    <section id="top" data-screen-label="Hero" style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: clamp(72px,8vh,90px) clamp(24px,5vw,84px) clamp(40px,6vh,72px); position: relative" data-hero-sec="">
      <div id="fm-hero" style="display:contents;"></div>
      <div style="display:flex;justify-content:space-between;align-items:baseline;border-bottom:1px solid rgba(30,58,138,0.12);padding-bottom:14px;margin-bottom:clamp(20px,4vh,40px);">
        <span data-anim="fm-rise" style="opacity:0;font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.32em;color:rgba(30,58,138,0.5);">PORTFOLIO — VOL.01</span>
        <span data-anim="fm-rise" data-rd="120" style="opacity:0;font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.32em;color:#FF9E80;">SINCE　2026</span>
      </div>

      <div id="fm-hero-wrap" style="">
        <h1 style="margin:0;font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(58px,12vw,184px);line-height:0.86;letter-spacing:-0.045em;">
          <span data-anim="fm-rise" data-rd="0" style="display:inline-block;opacity:0;color:#1E3A8A;">F</span><span data-anim="fm-rise" data-rd="55" style="display:inline-block;opacity:0;color:#1E3A8A;">U</span><span data-anim="fm-rise" data-rd="110" style="display:inline-block;opacity:0;color:#1E3A8A;">J</span><span data-anim="fm-rise" data-rd="165" style="display:inline-block;opacity:0;color:#1E3A8A;">I</span><span data-anim="fm-rise" data-rd="220" style="display:inline-block;opacity:0;color:#FF9E80;">M</span><span data-anim="fm-rise" data-rd="275" style="display:inline-block;opacity:0;color:#FF9E80;">O</span><span data-anim="fm-rise" data-rd="330" style="display:inline-block;opacity:0;color:#FF9E80;">M</span><span data-anim="fm-rise" data-rd="385" style="display:inline-block;opacity:0;color:#FF9E80;">O</span>
        </h1>
      </div>

      <!-- PINK BAND -->
      <div data-anim="fm-rise" data-rd="480" style="opacity:0;overflow:hidden;background:#FF9E80;padding:13px 0;transform:rotate(-1.1deg);margin:clamp(16px,3vh,30px) -6vw;box-shadow:0 10px 30px rgba(255,158,128,0.25);">
        <div style="display:flex;width:max-content;animation:fm-marquee 24s linear infinite;">
          <div style="display:flex;align-items:center;gap:30px;padding-right:30px;font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(15px,1.8vw,24px);letter-spacing:0.05em;color:#fff;white-space:nowrap;"><span>WEB DESIGN</span><span style="opacity:.55;">✦</span><span>LP / EC</span><span style="opacity:.55;">✦</span><span>GRAPHIC</span><span style="opacity:.55;">✦</span><span>BRANDING</span><span style="opacity:.55;">✦</span><span>ふじもも DESIGN</span><span style="opacity:.55;">✦</span><span>OSAKA</span><span style="opacity:.55;">✦</span></div>
          <div style="display:flex;align-items:center;gap:30px;padding-right:30px;font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(15px,1.8vw,24px);letter-spacing:0.05em;color:#fff;white-space:nowrap;"><span>WEB DESIGN</span><span style="opacity:.55;">✦</span><span>LP / EC</span><span style="opacity:.55;">✦</span><span>GRAPHIC</span><span style="opacity:.55;">✦</span><span>BRANDING</span><span style="opacity:.55;">✦</span><span>ふじもも DESIGN</span><span style="opacity:.55;">✦</span><span>OSAKA</span><span style="opacity:.55;">✦</span></div>
        </div>
      </div>

      <div data-anim="fm-rise" data-rd="540" style="opacity:0;display:flex;justify-content:space-between;align-items:baseline;margin-bottom:clamp(24px,4vh,44px);flex-wrap:wrap;gap:8px;">
        <span style="font-family:'Noto Sans JP',sans-serif;font-weight:500;font-size:clamp(14px,1.4vw,18px);color:#1E3A8A;letter-spacing:0.06em;">ふじもも ｜ Design</span>
        <span style="font-family:'Montserrat',sans-serif;font-style:italic;font-weight:400;font-size:clamp(13px,1.3vw,17px);color:rgba(15,23,42,0.5);">All about design.</span>
      </div>

      <div id="fm-hero-cards" data-col2="" style="display:grid;grid-template-columns:1fr 1.2fr;gap:clamp(16px,2vw,28px);position:relative;">
        <!-- Osaka stickers -->
        
        
        <div style="position:absolute;top:18px;left:20px;z-index:3;background:#FF9E80;color:#fff;font-family:'Montserrat',sans-serif;font-weight:800;font-size:9px;letter-spacing:0.16em;padding:5px 12px;border-radius:99px;">IT'S ME</div><div data-anim="fm-rise" data-rd="600" style="opacity:0;position:relative;background:rgba(255,255,255,0.6);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.7);box-shadow:0 8px 32px rgba(31,38,135,0.06);border-radius:26px;padding:14px;overflow:visible;">
          <img src="glico.png" alt="" class="fm-jerk2" style="position:absolute;z-index:6;top:-22px;right:-14px;width:clamp(96px,26vw,150px);height:auto;filter:drop-shadow(0 10px 18px rgba(15,23,42,0.18));pointer-events:none;">
          <img src="tsutenkaku.png" alt="" class="fm-jerk1" style="position:absolute;z-index:6;left:-16px;bottom:-22px;width:clamp(60px,16vw,110px);height:auto;filter:drop-shadow(0 10px 16px rgba(15,23,42,0.16));pointer-events:none;">
          
          
          
        <image-slot id="hero-portrait" src="itsme-photo.png" fit="cover" style="display:block;width:100%;height:clamp(280px,34vw,420px);" shape="rounded" radius="18" placeholder="人物写真"></image-slot></div><div data-anim="fm-rise" data-rd="680" style="opacity:0;position:relative;background:rgba(255,255,255,0.72);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.8);box-shadow:0 8px 32px rgba(31,38,135,0.06);border-radius:26px;padding:clamp(26px,3vw,44px);display:flex;flex-direction:column;justify-content:center;overflow:visible;">
          <div style="position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(255,158,128,0.12);filter:blur(20px);"></div>
          <span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:10px;letter-spacing:0.24em;color:#FF9E80;">CONCEPT</span>
          <h2 style="margin: 14px 0 18px; font-family: 'Noto Sans JP',sans-serif; font-weight: 700; font-size: clamp(24px,2.7vw,40px); line-height: 1.35; color: #1E3A8A; letter-spacing: 0.01em; position: relative">なんか、<div>めっちゃ<span style="font-size: clamp(24px, 2.7vw, 40px); letter-spacing: 0.01em; color: rgb(255, 158, 128);">ええ感じ</span><span style="font-size: clamp(24px, 2.7vw, 40px); letter-spacing: 0.01em;">。</span></div></h2>
          <p style="margin:0 0 22px;font-family:'Noto Sans JP',sans-serif;font-weight:300;font-size:clamp(12px,1.05vw,14px);line-height:1.95;color:rgba(15,23,42,0.78);max-width:42ch;">大阪出身の<span style="font-size: clamp(12px, 1.05vw, 14px);">Webデザイナー兼グラフィックデザイナー。</span><span style="font-size: clamp(12px, 1.05vw, 14px);">Webサイトからグラフィックまで、一貫して対応が可能です。</span>お客様にとことん寄り添い、「なんか、めっちゃええ感じ。」をお届けします。</p><div style="display:flex;flex-wrap:wrap;gap:8px;">
            <span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.05em;color:#1E3A8A;background:rgba(30,58,138,0.06);border:1px solid rgba(30,58,138,0.1);padding:6px 13px;border-radius:99px;">Figma</span>
            <span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.05em;color:#1E3A8A;background:rgba(30,58,138,0.06);border:1px solid rgba(30,58,138,0.1);padding:6px 13px;border-radius:99px;">Illustrator</span>
            <span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.05em;color:#1E3A8A;background:rgba(30,58,138,0.06);border:1px solid rgba(30,58,138,0.1);padding:6px 13px;border-radius:99px;">HTML / CSS</span>
            <span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.05em;color:#1E3A8A;background:rgba(30,58,138,0.06);border:1px solid rgba(30,58,138,0.1);padding:6px 13px;border-radius:99px;">JS / PHP</span>
          </div><p></p><div><span style="color: rgb(15, 23, 42); font-size: medium;"></span><span style="font-size: clamp(12px, 1.05vw, 14px);"></span></div><p></p><div></div><p></p>
          
