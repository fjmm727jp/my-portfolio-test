          <div data-anim="fm-rise" style="opacity:0;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">Figma / Canva</span><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">95</span></div>
            <div style="height:6px;background:rgba(30,58,138,0.08);border-radius:99px;overflow:hidden;"><div data-grow="" style="height: 100%; width: 80%; background: linear-gradient(90deg,#1E3A8A,#FF9E80); border-radius: 99px; transform-origin: left; transform: scaleX(0)"></div></div>
          </div>
          <div data-anim="fm-rise" data-rd="80" style="opacity:0;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">Illustrator</span><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">90</span></div>
            <div style="height:6px;background:rgba(30,58,138,0.08);border-radius:99px;overflow:hidden;"><div data-grow="" style="height: 100%; width: 85%; background: linear-gradient(90deg,#1E3A8A,#FF9E80); border-radius: 99px; transform-origin: left; transform: scaleX(0)"></div></div>
          </div>
          <div data-anim="fm-rise" data-rd="160" style="opacity:0;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">HTML / CSS</span><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">88</span></div>
            <div style="height:6px;background:rgba(30,58,138,0.08);border-radius:99px;overflow:hidden;"><div data-grow="" style="height:100%;width:88%;background:linear-gradient(90deg,#1E3A8A,#FF9E80);border-radius:99px;transform-origin:left;transform:scaleX(0);"></div></div>
          </div>
          <div data-anim="fm-rise" data-rd="240" style="opacity:0;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">JavaScript / PHP</span><span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#FF9E80;">75</span></div>
            <div style="height:6px;background:rgba(30,58,138,0.08);border-radius:99px;overflow:hidden;"><div data-grow="" style="height:100%;width:75%;background:linear-gradient(90deg,#1E3A8A,#FF9E80);border-radius:99px;transform-origin:left;transform:scaleX(0);"></div></div>
          </div><div data-anim="fm-rise" data-rd="240" style="opacity:0;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;"><span style="font-family: Montserrat, sans-serif; font-weight: 700; font-size: 14px; color: rgb(30, 58, 138);">やる気</span><span style="font-family: Montserrat, sans-serif; font-weight: 800; font-size: 13px; color: rgb(255, 158, 128);">100</span></div>
            <div style="height:6px;background:rgba(30,58,138,0.08);border-radius:99px;overflow:hidden;"><div data-grow="" style="height: 100%; width: 100%; background: linear-gradient(90deg,#1E3A8A,#FF9E80); border-radius: 99px; transform-origin: left; transform: scaleX(0)"></div></div>
          </div>

          <!-- CAN MAKE — emphasized -->
          <div data-anim="fm-rise" data-rd="320" style="opacity:0;position:relative;margin-top:14px;background:linear-gradient(135deg,#1E3A8A,#2747a8);border-radius:24px;padding:clamp(24px,2.6vw,34px);overflow:hidden;box-shadow:0 14px 36px rgba(30,58,138,0.18);">
            
            <div style="display:flex;align-items:baseline;gap:10px;position:relative;">
