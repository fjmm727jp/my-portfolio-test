            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:18px;position:relative;">
              <span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">HPサイト</span>
              <span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">LPサイト</span>
              <span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">ECサイト</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">チラシ</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">ロゴ</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">名刺</span>
              
              
              <span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">プレゼン資料</span><span style="font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;background:#fff;padding:9px 18px;border-radius:99px;">3つ折りパンフレット</span>
              
            </div>
          <div style="position: absolute; top: -33px; width: 140px; height: 140px; border-radius: 50%; background: rgba(255,158,128,0.25); filter: blur(26px); left: 449px"></div></div>
        </div><div data-anim="fm-rise" data-rd="180" style="opacity: 0; background: rgba(255,255,255,0.65); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.8); box-shadow: 0 8px 32px rgba(31,38,135,0.06); border-radius: 26px; padding: clamp(26px,3vw,40px); position: relative">
          <span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:10px;letter-spacing:0.2em;color:#FF9E80;">LICENSE / 資格</span>
          <div style="display:flex;flex-direction:column;gap:14px;margin-top:20px;">
            <div style="display:flex;align-items:center;gap:14px;border:1px solid rgba(30,58,138,0.1);background:rgba(255,255,255,0.5);border-radius:16px;padding:16px 18px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#FF9E80;flex-shrink:0;"></span>
              <div><h4 style="margin:0;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">Webデザイン技能検定 3級</h4><p style="margin:3px 0 0;font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.1em;color:#FF9E80;">NATIONAL CERTIFICATION / 国家資格</p></div>
            </div>
            <div style="display:flex;align-items:center;gap:14px;border:1px solid rgba(30,58,138,0.1);background:rgba(255,255,255,0.5);border-radius:16px;padding:16px 18px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#1E3A8A;flex-shrink:0;"></span>
              <div><h4 style="margin:0;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">色彩検定 2級</h4><p style="margin:3px 0 0;font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.1em;color:rgba(30,58,138,0.5);">COLOR COORDINATION</p></div>
            </div><div style="display:flex;align-items:center;gap:14px;border:1px solid rgba(30,58,138,0.1);background:rgba(255,255,255,0.5);border-radius:16px;padding:16px 18px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#1E3A8A;flex-shrink:0;"></span>
              <div><h4 style="margin:0;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;color:#1E3A8A;">世界遺産検定 2級（笑）</h4><p style="margin:3px 0 0;font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.1em;color:rgba(30,58,138,0.5);">TEST OF WORLD HERITAGE STUDY</p></div>
            </div>
          </div>
        </div>

        
      </div>
    </section><section id="contact" data-screen-label="Contact" style="background:#FF9E80;padding:clamp(70px,11vh,130px) clamp(24px,5vw,84px) clamp(40px,6vh,60px);position:relative;overflow:hidden;">
      <div style="position:absolute;top:-12vw;right:-6vw;width:46vw;height:46vw;border-radius:50%;background:rgba(255,255,255,0.16);filter:blur(40px);pointer-events:none;"></div>
      <span data-anim="fm-rise" style="opacity:0;display:block;font-family:'Montserrat',sans-serif;font-weight:800;font-size:11px;letter-spacing:0.28em;color:rgba(255,255,255,0.85);margin-bottom:16px;position:relative;">06 — CONTACT</span>
      <h2 data-anim="fm-rise" data-rd="100" style="opacity: 0; margin: 0 0 clamp(28px,4vh,44px); font-family: 'Montserrat',sans-serif; font-weight: 800; font-size: clamp(44px,6.5vw,128px); line-height: 0.88; letter-spacing: -0.03em; color: #FFF7F2; position: relative">LET'S CREATE<br>なんか、めっちゃええ感じ。</h2>
      <div data-col2="" style="display:grid;grid-template-columns:1fr 1.1fr;gap:clamp(28px,5vw,72px);align-items:start;position:relative;">
        
        <div data-anim="fm-rise" data-rd="180" style="opacity:0;">
          <p style="margin:0 0 20px;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:clamp(18px,2vw,26px);color:#fff;line-height:1.6;">いつも全力、100％</p>
          <p style="margin: 0 0 28px; font-family: 'Noto Sans JP',sans-serif; font-weight: 300; font-size: 14px; line-height: 2; color: rgba(255,255,255,0.9); max-width: 34ch; width: 300px">「頼みたいけど、どんなデザインが良いのかも分からん…」そんなフワッとした状態でも大丈夫です。まずは現状のモヤモヤを聞かせてください。いっしょに頭の中をほどいていきましょう。</p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;letter-spacing:0.06em;color:#fff;">ふじもも ｜ Design</span>
            <span style="font-family:'Montserrat',sans-serif;font-weight:500;font-size:11px;letter-spacing:0.16em;color:rgba(255,255,255,0.75);">WEB &amp; GRAPHIC DESIGNER — OSAKA, JP</span>
          </div>
        </div><div style="position:relative;">
          <img src="ohkini.png" alt="おおきに！" class="fm-jerk2" style="position:absolute;z-index:6;top:-30px;right:-8px;width:clamp(132px,14vw,170px);height:auto;filter:drop-shadow(0 10px 18px rgba(15,23,42,0.22));pointer-events:none;">
          
          <div data-thankyou="" style="display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;background:rgba(255,255,255,0.95);border-radius:26px;padding:60px 40px;box-shadow:0 18px 50px rgba(15,23,42,0.16);min-height:300px;gap:14px;">
            <div style="width:54px;height:54px;border-radius:50%;background:#1E3A8A;color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;">✓</div>
            <h3 style="margin:0;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:20px;color:#1E3A8A;">おおきに、受け取りました！</h3>
            <p style="margin:0;font-family:'Noto Sans JP',sans-serif;font-weight:300;font-size:13px;line-height:1.9;color:rgba(15,23,42,0.7);">なるはやで、折り返しご連絡します。<br>ちょっとだけ待っといてくださいね。</p>
          </div><form data-form="" data-anim="fm-rise" data-rd="260" style="opacity: 0; background: rgba(255,255,255,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.8); box-shadow: 0 18px 50px rgba(15,23,42,0.16); border-radius: 26px; padding: clamp(24px,3vw,40px); display: flex; flex-direction: column; gap: 16px; position: relative">
            <div data-col2="" style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
              <label style="display:flex;flex-direction:column;gap:6px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.16em;color:rgba(30,58,138,0.6);">お名前 *</span><input type="text" required="" placeholder="山田 太郎" style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#0F172A;border:1px solid rgba(30,58,138,0.16);background:#fff;border-radius:12px;padding:11px 14px;outline:none;"></label>
              <label style="display:flex;flex-direction:column;gap:6px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.16em;color:rgba(30,58,138,0.6);">メール *</span><input type="email" required="" placeholder="you@example.com" style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#0F172A;border:1px solid rgba(30,58,138,0.16);background:#fff;border-radius:12px;padding:11px 14px;outline:none;"></label>
            </div>
            <label style="display:flex;flex-direction:column;gap:6px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.16em;color:rgba(30,58,138,0.6);">ご相談内容</span>
              <select style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#0F172A;border:1px solid rgba(30,58,138,0.16);background:#fff;border-radius:12px;padding:11px 14px;outline:none;appearance:none;">
                <option>ホームページ制作</option><option>LP（ランディングページ）制作</option><option>ECサイト構築</option><option>グラフィック・印刷物</option><option>その他・まだ決まっていない</option>
              </select>
            </label>
            <label style="display:flex;flex-direction:column;gap:6px;"><span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:9px;letter-spacing:0.16em;color:rgba(30,58,138,0.6);">メッセージ</span><textarea rows="3" placeholder="「こんなん作れるん？」レベルでもOK。気軽にどうぞ！" style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#0F172A;border:1px solid rgba(30,58,138,0.16);background:#fff;border-radius:12px;padding:11px 14px;outline:none;resize:vertical;"></textarea></label>
            <button type="submit" style="margin-top: 4px; font-family: 'Montserrat',sans-serif; font-weight: 800; font-size: 13px; letter-spacing: 0.08em; color: #fff; background: #1E3A8A; border: none; border-radius: 99px; padding: 15px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; position: relative">まずは無料で相談する <span style="font-size:15px;">↗</span></button>
          <img src="./takoyaki_maido-mqss8rmv.png" alt="" class="fm-jerk3" style="position:absolute;z-index:5;left:-20px;bottom:-10px;width:clamp(72px,15vw,118px);height:auto;filter:drop-shadow(0 8px 14px rgba(15,23,42,0.12));pointer-events:none;"></form>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;border-top:1px solid rgba(255,255,255,0.3);margin-top:clamp(48px,7vh,80px);padding-top:24px;position:relative;">
        <span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:16px;color:#fff;letter-spacing:-0.02em;">FUJIMOMO</span>
        <span style="font-family:'Montserrat',sans-serif;font-weight:500;font-size:10px;letter-spacing:0.12em;color:rgba(255,255,255,0.75);">© 2026 ふじもも ｜ Design — All about design.</span>
      </div>
    </section>

  </main>
</div>
</x-dc>
<script type="text/x-dc" data-dc-script>
class Component extends DCLogic {
  componentDidMount() {
    this._active = null;
    this._t0 = performance.now();
    this._car = 0;
    this._curX = null;
    ['update','tick','onScroll','onClick','onSubmit','onDown','onMove','onUp','onOver'].forEach((m) => { this[m] = this[m].bind(this); });

    window.addEventListener('scroll', this.onScroll, { passive: true });
    window.addEventListener('resize', this.onResize = () => { this._curX = null; this.positionCarousel(false); this.update(); });
    document.addEventListener('click', this.onClick);
    document.addEventListener('submit', this.onSubmit);
    document.addEventListener('mousedown', this.onDown);
    document.addEventListener('mousemove', this.onMove);
    document.addEventListener('mouseup', this.onUp);
    document.addEventListener('mouseover', this.onOver);

    this._raf = requestAnimationFrame(this.tick);
  }

  componentWillUnmount() {
    window.removeEventListener('scroll', this.onScroll);
    window.removeEventListener('resize', this.onResize);
    document.removeEventListener('click', this.onClick);
    document.removeEventListener('submit', this.onSubmit);
    document.removeEventListener('mousedown', this.onDown);
    document.removeEventListener('mousemove', this.onMove);
    document.removeEventListener('mouseup', this.onUp);
    document.removeEventListener('mouseover', this.onOver);
    if (this._raf) cancelAnimationFrame(this._raf);
  }

  tick() {
    this.update();
    if (this._curX === null) this.positionCarousel(false);
    // run continuously: CSS-frozen contexts aside, this keeps reveals,
    // scroll-spy and carousel self-healing against any late re-render.
    this._raf = requestAnimationFrame(this.tick);
  }

  onScroll() {
    if (this._pending) return;
    this._pending = true;
    requestAnimationFrame(() => { this._pending = false; this.update(); });
  }

  cards() { const r = document.getElementById('fm-root'); return r ? Array.from(r.querySelectorAll('[data-card]')) : []; }

  positionCarousel(animate) {
    const root = document.getElementById('fm-root');
    if (!root) return;
    const cont = root.querySelector('#fm-carousel');
    const track = root.querySelector('[data-track]');
    if (!cont || !track) return;
    const cards = this.cards();
    if (!cards.length) return;
    const cw = Math.min(380, Math.max(220, cont.clientWidth * 0.6));
    const gap = 24;
    cards.forEach((c, i) => {
      c.style.width = cw + 'px';
      const on = i === this._car;
      c.style.transform = 'scale(' + (on ? 1 : 0.82) + ')';
      c.style.opacity = on ? '1' : '0.8';
      c.style.zIndex = on ? '2' : '1';
    });
    const targetX = cont.clientWidth / 2 - this._car * (cw + gap) - cw / 2;
    if (animate && this._curX !== null) {
      this.tweenX(track, this._curX, targetX, 480);
    } else {
      track.style.transform = 'translateX(' + targetX + 'px)';
      this._curX = targetX;
    }
    // dots
    const dots = root.querySelector('[data-dots]');
    if (dots) {
      if (dots.children.length !== cards.length) {
        dots.innerHTML = '';
        cards.forEach((c, i) => {
          const d = document.createElement('button');
          d.setAttribute('data-dot', i);
          d.style.cssText = 'border:none;cursor:pointer;padding:0;height:8px;border-radius:99px;';
          dots.appendChild(d);
        });
      }
      Array.from(dots.children).forEach((d, i) => {
        const on = i === this._car;
        d.style.width = on ? '26px' : '8px';
        d.style.background = on ? '#FF9E80' : 'rgba(255,255,255,0.3)';
      });
    }
  }

  tweenX(track, from, to, dur) {
    if (this._tw) cancelAnimationFrame(this._tw);
    const start = performance.now();
    const step = (t) => {
      const p = Math.min(1, (t - start) / dur);
      const e = 1 - Math.pow(1 - p, 3);
      const x = from + (to - from) * e;
      track.style.transform = 'translateX(' + x + 'px)';
      this._curX = x;
      if (p < 1) this._tw = requestAnimationFrame(step);
    };
    this._tw = requestAnimationFrame(step);
  }

  goTo(i, animate) {
    const n = this.cards().length;
    if (!n) return;
    this._car = ((i % n) + n) % n;
    this.positionCarousel(animate !== false);
  }

  update() {
    const root = document.getElementById('fm-root');
    if (!root) return;
    const vh = window.innerHeight;
    const y = window.scrollY;

    // reveal / grow — JS rAF tweens (CSS animations are frozen in some render
    // contexts; JS rAF always advances). Self-healing safety net re-forces the
    // final state for finished elements in case a re-render reverts inline.
    root.querySelectorAll('[data-anim]').forEach((el) => {
      const r = el.getBoundingClientRect();
      if (r.top < vh * 0.92 && r.bottom > -40) this.revealEl(el);
      if (el._rvDone) { el.style.opacity = '1'; el.style.transform = 'none'; }
    });
    root.querySelectorAll('[data-grow]').forEach((el) => {
      const r = el.getBoundingClientRect();
      if (r.top < vh * 0.92 && r.bottom > -40) this.growEl(el);
      if (el._gDone) el.style.transform = 'scaleX(1)';
    });

    // count-up
    root.querySelectorAll('[data-count]').forEach((el) => {
      const r = el.getBoundingClientRect();
      if (!el._done && r.top < vh * 0.85 && r.bottom > 0) { el._done = true; this.countUp(el); }
    });

    // progress
    const h = document.documentElement.scrollHeight - vh;
    const prog = root.querySelector('[data-progress]');
    if (prog) prog.style.height = (h > 0 ? (y / h) * 100 : 0) + '%';

    // parallax
    root.querySelectorAll('[data-parallax]').forEach((el) => { el.style.transform = 'translate3d(0,' + (y * parseFloat(el.getAttribute('data-parallax'))) + 'px,0)'; });
    root.querySelectorAll('[data-drift]').forEach((el) => { el.style.transform = 'translate3d(' + (y * parseFloat(el.getAttribute('data-drift'))) + 'px,0,0)'; });

    // self-heal carousel layout if reverted
    const track = root.querySelector('[data-track]');
    if (track && !track.style.transform) this.positionCarousel(false);

    // scroll-spy + CTA hide on contact
    const ids = ['top','about','works','career','why','skills','contact'];
    const mid = y + vh * 0.35;
    let active = 'top';
    ids.forEach((id) => { const s = document.getElementById(id); if (s && s.offsetTop <= mid) active = id; });
    this._active = active;
    root.querySelectorAll('#fm-spine [data-nav]').forEach((a) => {
      const on = a.getAttribute('data-nav') === active;
      const num = a.querySelector('[data-num]');
      const lab = a.querySelector('[data-label]');
      const ind = a.querySelector('[data-ind]');
      if (num) { num.style.color = on ? '#1E3A8A' : 'rgba(30,58,138,0.38)'; num.style.transform = on ? 'scale(1.18)' : 'scale(1)'; }
      if (lab) lab.style.color = on ? '#FF9E80' : 'rgba(30,58,138,0.32)';
      if (ind) ind.style.height = on ? '22px' : '0px';
    });
    const cta = document.getElementById('fm-cta');
    if (cta) {
      const hide = active === 'contact';
      cta.style.opacity = hide ? '0' : '1';
      cta.style.transform = hide ? 'scale(0)' : 'scale(1)';
      cta.style.pointerEvents = hide ? 'none' : 'auto';
    }
  }

  onClick(e) {
    const T = e.target;
    const nav = T.closest && T.closest('[data-nav]');
    if (nav) { e.preventDefault(); if (this._ovOpen) this.closeWorks(); this.scrollToId(nav.getAttribute('data-nav')); const m = document.getElementById('fm-menu'); if (m) m.style.display = 'none'; return; }
    if (T.closest && T.closest('#fm-burger')) { const m = document.getElementById('fm-menu'); if (m) m.style.display = 'flex'; return; }
    if (T.closest && T.closest('#fm-menu-close')) { const m = document.getElementById('fm-menu'); if (m) m.style.display = 'none'; return; }
    if (T.closest && T.closest('#fm-cta')) { this.scrollToId('contact'); return; }
    if (T.closest && T.closest('[data-arrow="left"]')) { this.goTo(this._car - 1); return; }
    if (T.closest && T.closest('[data-arrow="right"]')) { this.goTo(this._car + 1); return; }
    const dot = T.closest && T.closest('[data-dot]');
    if (dot) { this.goTo(parseInt(dot.getAttribute('data-dot'), 10)); return; }
    if (T.closest && T.closest('[data-works-more]')) { this.openWorks(); return; }
    if (T.closest && T.closest('[data-works-close]')) { this.closeWorks(); return; }
    const fil = T.closest && T.closest('[data-filter]');
    if (fil) { this.setFilter(fil.getAttribute('data-filter')); return; }
    const wo = T.closest && T.closest('[data-work-open]');
    if (wo) { this.openDetail(wo.getAttribute('data-work-open')); return; }
    if (T.closest && T.closest('[data-detail-back]')) { this.closeDetail(); return; }
  }

  setFilter(g) {
    const ov = document.getElementById('fm-works-overlay');
    if (!ov) return;
    ov.querySelectorAll('[data-filter]').forEach((b) => {
      const on = b.getAttribute('data-filter') === g;
      b.style.background = on ? '#FF9E80' : '#fff';
      b.style.color = '#0E1F52';
      b.style.borderColor = on ? '#FF9E80' : '#fff';
    });
    ov.querySelectorAll('[data-works-card]').forEach((c) => {
      const show = g === 'all' || c.getAttribute('data-genre') === g;
      c.style.display = show ? '' : 'none';
    });
  }

  openDetail(i) {
    const ov = document.getElementById('fm-works-overlay');
    if (!ov) return;
    const tabs = ov.querySelector('[data-ov-tabs]');
    const grid = ov.querySelector('[data-ov-grid]');
    const detail = ov.querySelector('[data-ov-detail]');
    if (tabs) tabs.style.display = 'none';
    if (grid) grid.style.display = 'none';
    if (detail) detail.style.display = 'block';
    ov.querySelectorAll('[data-detail]').forEach((d) => {
      d.style.display = d.getAttribute('data-detail') === String(i) ? 'block' : 'none';
    });
    const _c = ov.querySelector('[data-ov-content]'); if (_c) _c.scrollTop = 0;
    if (detail) { detail.style.animation = 'none'; void detail.offsetWidth; detail.style.animation = 'fm-ovcontent .5s cubic-bezier(.16,1,.3,1) both'; }
  }

  closeDetail() {
    const ov = document.getElementById('fm-works-overlay');
    if (!ov) return;
    const tabs = ov.querySelector('[data-ov-tabs]');
    const grid = ov.querySelector('[data-ov-grid]');
    const detail = ov.querySelector('[data-ov-detail]');
    if (detail) detail.style.display = 'none';
    if (tabs) tabs.style.display = 'flex';
    if (grid) grid.style.display = 'grid';
    const _c = ov.querySelector('[data-ov-content]'); if (_c) _c.scrollTop = 0;
  }

  openWorks() {
    const ov = document.getElementById('fm-works-overlay');
    if (!ov || this._ovOpen) return;
    this._ovOpen = true;
    ov.style.display = 'block';
    const _c = ov.querySelector('[data-ov-content]'); if (_c) _c.scrollTop = 0;
    this.closeDetail();
    this.setFilter('all');
    this._prevBodyOverflow = document.body.style.overflow;
    document.body.style.overflow = 'hidden';
    const cta = document.getElementById('fm-cta'); if (cta) cta.style.visibility = 'hidden';
    const burger = document.getElementById('fm-burger'); if (burger) burger.style.visibility = 'hidden';
    const content = ov.querySelector('[data-ov-content]');
    ov.style.animation = 'none';
    if (content) content.style.animation = 'none';
    void ov.offsetWidth;
    ov.style.animation = 'fm-ovin .62s cubic-bezier(.16,1,.3,1) forwards';
    if (content) content.style.animation = 'fm-ovcontent .55s cubic-bezier(.16,1,.3,1) .32s both';
  }

  closeWorks() {
    const ov = document.getElementById('fm-works-overlay');
    if (!ov || !this._ovOpen) return;
    const content = ov.querySelector('[data-ov-content]');
    if (content) content.style.animation = 'none';
    ov.style.animation = 'none';
    void ov.offsetWidth;
    ov.style.animation = 'fm-ovout .5s cubic-bezier(.16,1,.3,1) forwards';
    const done = () => {
      ov.removeEventListener('animationend', done);
      ov.style.display = 'none';
      this._ovOpen = false;
      document.body.style.overflow = this._prevBodyOverflow || '';
      const cta = document.getElementById('fm-cta'); if (cta) cta.style.visibility = '';
      const burger = document.getElementById('fm-burger'); if (burger) burger.style.visibility = '';
    };
    ov.addEventListener('animationend', done);
  }

  onSubmit(e) {
    const form = e.target.closest && e.target.closest('[data-form]');
    if (!form) return;
    e.preventDefault();
    form.style.display = 'none';
    const ty = document.querySelector('[data-thankyou]');
    if (ty) ty.style.display = 'flex';
  }

  onDown(e) {
    const car = e.target.closest && e.target.closest('#fm-carousel');
    if (!car) return;
    const track = document.querySelector('[data-track]');
    if (!track) return;
    this._drag = { x: e.pageX, startX: this._curX || 0, moved: 0, track };
    track.style.cursor = 'grabbing';
  }
  onMove(e) {
    if (!this._drag) return;
    e.preventDefault();
    const dx = e.pageX - this._drag.x;
    this._drag.moved = dx;
    this._drag.track.style.transform = 'translateX(' + (this._drag.startX + dx) + 'px)';
    this._curX = this._drag.startX + dx;
  }
  onUp() {
    if (!this._drag) return;
    const dx = this._drag.moved;
    this._drag.track.style.cursor = 'grab';
    this._drag = null;
    if (dx > 60) this.goTo(this._car - 1);
    else if (dx < -60) this.goTo(this._car + 1);
    else this.goTo(this._car);
  }

  onOver(e) {
    const c = e.target.closest && e.target.closest('#fm-cta');
    if (!c) return;
    const inner = c.querySelector('.fm-cta-inner');
    if (inner && !inner.style.animationName) {
      inner.style.animation = 'fm-rotate .7s cubic-bezier(.16,1,.3,1)';
      inner.addEventListener('animationend', () => { inner.style.animation = ''; }, { once: true });
    }
  }

  revealEl(el) {
    if (el._rv) return; el._rv = 1;
    el.style.animation = 'none';
    const delay = parseFloat(el.getAttribute('data-rd') || 0);
    const dur = 720, dist = 26;
    const begin = performance.now() + delay;
    const step = (t) => {
      let p = (t - begin) / dur;
      if (p < 0) { el.style.opacity = '0'; el.style.transform = 'translateY(' + dist + 'px)'; requestAnimationFrame(step); return; }
      p = Math.min(1, p);
      const e = 1 - Math.pow(1 - p, 3);
      el.style.opacity = String(e);
      el.style.transform = p < 1 ? 'translateY(' + (dist * (1 - e)) + 'px)' : 'none';
      if (p < 1) requestAnimationFrame(step);
      else { el._rvDone = 1; el.style.opacity = '1'; el.style.transform = 'none'; }
    };
    requestAnimationFrame(step);
  }

  growEl(el) {
    if (el._g) return; el._g = 1;
    el.style.animation = 'none';
    const dur = 1100;
    const begin = performance.now();
    const step = (t) => {
      const p = Math.min(1, (t - begin) / dur);
      const e = 1 - Math.pow(1 - p, 3);
      el.style.transform = 'scaleX(' + e + ')';
      if (p < 1) requestAnimationFrame(step);
      else { el._gDone = 1; el.style.transform = 'scaleX(1)'; }
    };
    requestAnimationFrame(step);
  }

  scrollToId(id) {
    const el = document.getElementById(id);
    if (!el) return;
    const y = el.getBoundingClientRect().top + window.scrollY - 6;
    window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
  }

  countUp(el) {
    const target = parseFloat(el.getAttribute('data-count'));
    const suffix = el.getAttribute('data-suffix') || '';
    const dur = 1200;
    const start = performance.now();
    const step = (t) => {
      const p = Math.min(1, (t - start) / dur);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * ease) + suffix;
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  renderVals() { return {}; }
}
</script>
</body>
</html>
